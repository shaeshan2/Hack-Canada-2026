# =============================================================================
# DeedScan — Environment variables
# Copy to .env and fill in values. Required vars are needed for auth and DB.
# =============================================================================

# --- Auth0 (required for login/signup) ---
AUTH0_SECRET=replace-with-long-random-string
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.auth0.com
AUTH0_CLIENT_ID=YOUR_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_CLIENT_SECRET
# Optional: some code uses AUTH0_DOMAIN (e.g. tenant.auth0.com)
AUTH0_DOMAIN=YOUR_TENANT.auth0.com

# --- Database (required) ---
# SQLite for local dev; use PostgreSQL URL for production
DATABASE_URL=file:./dev.db

# --- App (optional) ---
# Base URL for App Clip QR codes (no trailing slash). Used by POST /api/qr/generate
NEXT_PUBLIC_APP_CLIP_URL=https://deedscan.app/clip

# --- Optional: AI & services ---
# Gemini API key for POST /api/price-estimate (AI price range). Omit for mock.
# GEMINI_API_KEY=your_gemini_api_key

# WebSocket chat server port (default 3001). Used by server/ws-server.js
# WS_PORT=3001

# --- Optional: uploads ---
# Local: directory relative to project root for photo uploads (default: public/uploads)
# UPLOAD_DIR=public/uploads
# For S3/Vultr Object Storage later: UPLOAD_PROVIDER=s3
# UPLOAD_PROVIDER=local
